# Secrets for FaithfulVoice's imported PRISM GraphRAG stack.
# See README.md for provider switching (Modal / local vLLM / Fireworks+Groq).

# Neo4j — always required
NEO4J_PASSWORD=your_neo4j_password

# LLM API key — not needed for Modal or local vLLM (defaults to "not-needed")
# Only needed if using Fireworks as the LLM provider
LLM_API_KEY=your_fireworks_api_key
FIREWORKS_API_KEY=your_fireworks_api_key

# Groq — only needed if using Groq vision fallback
GROQ_API_KEY=your_groq_api_key

# Langfuse — observability (not set up yet)
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx

# PostgreSQL is unused by the imported GraphRAG code, but config.py supports it
# for compatibility with the original PRISM snapshot.
DATABASE_URL=
